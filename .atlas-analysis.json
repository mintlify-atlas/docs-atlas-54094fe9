  "keyFeatures": [
    "Deep AI-powered research on any topic",
    "Multi-source research from documents, URLs, and manual text",
    "AI-generated comprehensive summaries using CrewAI agents",
    "Interactive Q&A chat with vector-powered semantic search",
    "AI-generated podcast-style audio overviews with multiple voices",
    "Automatic FAQ generation from research content",
    "Interactive visual mindmaps with hierarchical structure",
    "Global web access via Bright Data bypassing geo-restrictions"
  ],
  "publicApiSurface": [
    "POST /api/research/topic - Start topic research",
    "POST /api/research/sources - Start sources research",
    "GET /api/research/{task_id}/status - Get research status",
    "POST /api/chat - Chat with research content",
    "POST /api/research/{task_id}/audio - Generate audio overview",
    "POST /api/research/{task_id}/mindmap - Generate mindmap",
    "WebScrapingPlanner - Plans web scraping strategy",
    "LinkCollector - Discovers relevant sources using search_engine",
    "WebScraper - Extracts content using scrape_as_markdown",
    "ResearchAnalyst - Synthesizes information from sources",
    "ContentWriter - Creates engaging research summaries",
    "FAQGenerator - Generates relevant Q&A pairs",
    "MindmapCreator - Creates hierarchical visual mindmaps",
    "PodcastScriptGenerator - Creates audio overview scripts"
  ]
}
